<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectMobilBD.Views.EmpleadoPage"
             Title="{Binding TituloPagina}"
             BackgroundColor="#F0F4F8">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <ActivityIndicator IsVisible="{Binding LoadingEsVisible}"
                               IsRunning="{Binding LoadingEsVisible}"
                               Color="#1E3A5F"
                               HeightRequest="32"
                               Margin="0,0,0,16"/>

            <!-- Card del formulario -->
            <Border Padding="20,18"
                    BackgroundColor="White"
                    HorizontalOptions="FillAndExpand">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Border.Stroke>#DDE4EE</Border.Stroke>

                <VerticalStackLayout Spacing="0">

                    <!-- Nombre Completo -->
                    <Label Text="Nombre Completo"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#6B7A99"
                           Margin="0,0,0,4"/>
                    <Border Padding="12,0"
                            HeightRequest="44"
                            BackgroundColor="#F7F9FC"
                            Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.Stroke>#DDE4EE</Border.Stroke>
                        <Entry Text="{Binding EmpleadoDto.NombreCompleto}"
                               VerticalOptions="Center"
                               FontSize="14"
                               TextColor="#2D3A50"
                               PlaceholderColor="#B0BAD0"
                               Placeholder="Ej. Juan Pérez López"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Correo -->
                    <Label Text="Correo Electrónico"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#6B7A99"
                           Margin="0,0,0,4"/>
                    <Border Padding="12,0"
                            HeightRequest="44"
                            BackgroundColor="#F7F9FC"
                            Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.Stroke>#DDE4EE</Border.Stroke>
                        <Entry Text="{Binding EmpleadoDto.Correo}"
                               VerticalOptions="Center"
                               FontSize="14"
                               TextColor="#2D3A50"
                               PlaceholderColor="#B0BAD0"
                               Placeholder="ejemplo@correo.com"
                               Keyboard="Email"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Sueldo -->
                    <Label Text="Sueldo"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#6B7A99"
                           Margin="0,0,0,4"/>
                    <Border Padding="12,0"
                            HeightRequest="44"
                            BackgroundColor="#F7F9FC"
                            Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.Stroke>#DDE4EE</Border.Stroke>
                        <Entry Text="{Binding EmpleadoDto.Sueldo}"
                               Keyboard="Numeric"
                               VerticalOptions="Center"
                               FontSize="14"
                               TextColor="#1A7A4A"
                               FontAttributes="Bold"
                               PlaceholderColor="#B0BAD0"
                               Placeholder="0.00"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Fecha Contrato -->
                    <Label Text="Fecha de Contrato"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#6B7A99"
                           Margin="0,0,0,4"/>
                    <Border Padding="12,0"
                            HeightRequest="44"
                            BackgroundColor="#F7F9FC"
                            Margin="0,0,0,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.Stroke>#DDE4EE</Border.Stroke>
                        <DatePicker Date="{Binding EmpleadoDto.FechaContrato}"
                                    VerticalOptions="Center"
                                    FontSize="14"
                                    TextColor="#2D3A50"
                                    BackgroundColor="Transparent"
                                    Format="dd/MM/yyyy"/>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Botón Guardar -->
            <Button Text="Guardar"
                    Command="{Binding GuardarCommand}"
                    BackgroundColor="#1E3A5F"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="10"
                    HeightRequest="48"
                    HorizontalOptions="FillAndExpand"
                    Margin="0,16,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>